---
import ScrollReveal from './ScrollReveal';
import { otherProjects } from '../data/otherProjects';
import FilterableProjectGrid from './FilterableProjectGrid';
---

<div class="mt-24 md:mt-32">
  <ScrollReveal client:load variant="slide-up" duration={500} threshold={0.2} distance={20}>
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-[var(--color-text-primary)] mb-4" style="text-wrap: balance;">
        Other Noteworthy Projects
      </h2>
    </div>
  </ScrollReveal>

  <FilterableProjectGrid projects={otherProjects} client:load />
</div>
